# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string
# For Docker Compose, the hostname is "db" (the service name)
# For Cloud SQL, run the Auth Proxy first:
#   ./cloud-sql-proxy holdsworth-app:us-central1:holdsworth-db
DATABASE_URL=postgresql://holdsworth_app:password@localhost:5432/holdsworth

# ─── Google AI ──────────────────────────────────────────────
# Gemini API key for card scanning + grading analysis
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ─── Google Cloud Storage ──────────────────────────────────
# Card photos are stored in GCS
# Requires GOOGLE_APPLICATION_CREDENTIALS or default credentials
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── eBay API ───────────────────────────────────────────────
# eBay Browse API credentials for active listings
# Register at: https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ─── Auth (optional, skip for local dev) ───────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH_SECRET=
